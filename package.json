{
  "name": "omp-codex-computer",
  "version": "0.1.4",
  "description": "OMP extension for using OpenAI Codex Computer Use through Codex app-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastertyko/omp-codex-computer.git"
  },
  "bugs": {
    "url": "https://github.com/mastertyko/omp-codex-computer/issues"
  },
  "homepage": "https://github.com/mastertyko/omp-codex-computer#readme",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "skills",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "sh -c 'if find src tests -name \"*.ts\" -print -quit 2>/dev/null | grep -q .; then tsc --noEmit; else echo \"No TypeScript files yet; skipping typecheck\"; fi'",
    "check": "bun run typecheck && bun run test",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "bun run check && npm pack --dry-run"
  },
  "keywords": [
    "omp",
    "omp-plugin",
    "oh-my-pi",
    "oh-my-pi-plugin",
    "codex",
    "codex-computer-use",
    "computer-use"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": ">=16.3.6"
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "16.3.6",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "omp": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  }
}
